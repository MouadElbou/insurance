{
  "name": "insurance-broker-tracker",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "build:shared": "pnpm --filter shared build",
    "build:backend": "pnpm --filter backend build",
    "build:desktop": "pnpm --filter desktop build",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter backend test",
    "test:desktop": "pnpm --filter desktop test",
    "test:shared": "pnpm --filter shared test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "electron",
      "esbuild",
      "prisma"
    ]
  }
}
