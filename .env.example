# ─── PostgreSQL (used by docker-compose) ─────────────────────────
POSTGRES_USER=insurance
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=insurance_tracker
POSTGRES_PORT=5432

# ─── Backend ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Database connection (matches docker-compose service name "postgres")
DATABASE_URL="postgresql://insurance:change-me-to-a-strong-password@postgres:5432/insurance_tracker?schema=public"

# JWT secrets (REQUIRED — generate with: openssl rand -base64 48)
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-another-random-secret-at-least-32-chars

# JWT token expiry (optional, shown with defaults)
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d

# CORS allowed origins (comma-separated for multiple)
# For Electron production app use: app://.,file://
# For development add: http://localhost:5173
CORS_ORIGIN="app://.,file://"

# Bcrypt hash rounds (optional, default: 12)
# BCRYPT_ROUNDS=12

# ─── Caddy ───────────────────────────────────────────────────────
# Your production domain (Caddy will auto-provision HTTPS via Let's Encrypt)
DOMAIN=insurance.example.com
